{
	"bundle-id": "com.index.cubegame",
	"name": "CubeGame",
	"build-directory": "Builds",
	"release-directory": "Releases",
	"cmake-build-type": "Release",
	"cmake-parameters": "",
	"cmake-targets~android": [
		"Rayne",
		"RayneJolt",
		"RayneVulkan",
		"RayneUI",
		"RayneFlexUI",
		"RayneVR",
		"RayneOpenXR",
		"zlibstatic",
		"zip",
		"jansson",
		"png_static",
		"CubeGame"
	],
	"permissions~android": [
		{
			"type": "feature",
			"name": "com.oculus.feature.PASSTHROUGH",
			"required": true
		},
		{
			"type": "permission",
			"name": "com.oculus.permission.HAND_TRACKING"
		},
		{
			"type": "metadata",
			"name": "com.oculus.handtracking.frequency",
			"value": "HIGH"
		},
		{
			"type": "feature",
			"name": "oculus.software.handtracking"
		}
	],
	"keystore~android": "../../AndroidReleaseKeyStore",
	"build-secrets": "Other/build-secrets.json",
	"dependencies": {}
}
